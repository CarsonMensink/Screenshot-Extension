{
    "name": "Screenshot Tool",
    "description": "Mark two corners and copy that to your clipboard.",
    "version": "1.0",
    "manifest_version": 3,
    "background": {
        "service_worker": "script.js"
    },
    "permissions": [
        "contextMenus",
        "scripting",
        "clipboardWrite",
        "activeTab",
        "storage"
    ],
    "host_permissions": [
        "http://*/*",
        "https://*/*"
    ],
    "content_scripts": [
        {
            "matches": ["http://*/*", "https://*/*"],
            "js": ["content.js"]
        }
    ],
    "icons": {
        "16": "assets/icon.png",
        "48": "assets/icon.png"
    },
    "action": {
        "default_popup": "popup.html",
        "default_icon": "assets/icon.png"
    },
    "browser_specific_settings": {
        "gecko": {
            "id": "screenshot-tool@carsonmensink.local",
            "strict_min_version": "109.0"
        }
    }
}
